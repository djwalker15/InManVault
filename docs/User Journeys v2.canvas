		},
		{
			"id": "m000000000000061",
			"type": "text",
			"text": "**[MOCK: Cooking Mode]**\n\nSplit view: recipe steps on left, ingredient checklist with \"Use\" buttons on right. Progressive checkmarks. Running cost total.",
